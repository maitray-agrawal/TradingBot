[flake8]
max-line-length = 127
max-complexity = 12
extend-ignore =
    # E203: whitespace before ':' (conflicts with black)
    E203,
    # W503: line break before binary operator (conflicts with black)
    W503,
    # E501: line too long (handled by max-line-length above)
    E501

per-file-ignores =
    # Allow wildcard imports and unused imports in __init__ files
    __init__.py: F401, F403
    # Allow unused imports in conftest (fixtures used by other modules)
    conftest.py: F401
    # Allow longer lines in test files
    tests/*: E501

exclude =
    .git,
    __pycache__,
    venv,
    .venv,
    htmlcov,
    build,
    dist,
    *.egg-info,
    .pytest_cache,
    .mypy_cache,
    dashboard/,
