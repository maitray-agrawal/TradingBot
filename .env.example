# ==============================================================================
# PrimeTrade AI - Environment Configuration Template
# Copy this file to .env and fill in your details before running the project.
# ==============================================================================

# Binance Futures Testnet Credentials
BINANCE_API_KEY=your_binance_testnet_api_key_here
BINANCE_SECRET_KEY=your_binance_testnet_secret_key_here
TESTNET_URL=https://testnet.binancefuture.com

# System Environment Settings
# Options: DEVELOPMENT, STAGING, PRODUCTION
PROJECT_ENV=DEVELOPMENT

# Logging Level
# Options: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Data Ingestion Directory Path
DATA_DIRECTORY=data
